# ~/.aliases-info
# =============================
# Command Information / Cheat Sheet Aliases
# Each alias prints most useful commands (max 30 lines)
# Prefix: info.*
# =============================

# -----------------------------
# Docker info
# Prefix: info.docker
# -----------------------------
alias info.docker='echo -e "
Docker Commands (Most Useful):

1. List containers:               docker ps -a
2. List running containers:       docker ps
3. Start container:               docker start <container_name>
4. Stop container:                docker stop <container_name>
5. Remove container:              docker rm <container_name>
6. Run container interactively:   docker run -it <image>
7. View logs:                     docker logs <container_name>
8. List images:                   docker images
9. Remove image:                  docker rmi <image>
10. Build image:                  docker build -t <tag> <path>
11. Pull image:                   docker pull <image>
12. Push image:                   docker push <image>
13. Exec into container:          docker exec -it <container_name> /bin/bash
14. Inspect container:            docker inspect <container_name>
15. Remove all stopped containers:docker container prune
16. Remove all unused images:     docker image prune -a
17. Display Docker version:       docker --version
18. Display Docker info:          docker info
"'

