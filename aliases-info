# -----------------------------
# SSH info
# Prefix: info.ssh
# -----------------------------
alias info.ssh='echo -e "
SSH Commands (Most Useful):

1. Connect to host:               ssh user@host
2. Copy file to remote:           scp file user@host:/path/
3. Copy directory to remote:      scp -r dir user@host:/path/
4. Forward local port:            ssh -L local_port:host:remote_port user@host
5. Forward remote port:           ssh -R remote_port:host:local_port user@host
6. Test connection:               ssh -T user@host
7. Use identity file:             ssh -i ~/.ssh/id_rsa user@host
8. Check SSH agent identities:    ssh-add -l
9. Add identity to agent:         ssh-add ~/.ssh/id_rsa
10. Enable verbose mode:          ssh -v user@host
11. Copy keys to remote:          ssh-copy-id user@host
12. List known hosts:             cat ~/.ssh/known_hosts
"'

# -----------------------------
# Git info
# Prefix: info.git
# -----------------------------
alias info.git='echo -e "
Git Commands (Most Useful):

1. Status:                        git status
2. View log:                       git log --oneline --graph --decorate
3. Add changes:                     git add <file_or_dir>
4. Commit changes:                  git commit -m \"message\"
5. Push branch:                     git push origin <branch>
6. Pull branch:                     git pull origin <branch>
7. Create branch:                   git checkout -b <branch>
8. Switch branch:                   git checkout <branch>
9. Merge branch:                    git merge <branch>
10. Stash changes:                  git stash save \"message\"
11. Apply stash:                    git stash pop
12. View changes:                   git diff
13. Add remote:                      git remote add origin <repo>
14. Set upstream:                    git push -u origin <branch>
15. View remotes:                    git remote -v
16. Show commit details:             git show <commit_hash>
17. Reset changes:                   git reset --hard <commit_hash>
18. Remove file from index:          git rm <file>
19. Rename file:                     git mv <old> <new>
20. Tag commit:                      git tag <tag_name>
21. Push tags:                       git push origin --tags
22. View stash list:                 git stash list
23. Apply stash selectively:         git stash apply stash@{n}
24. Discard changes:                 git checkout -- <file>
25. Clone repo via SSH:              git clone git@github.com:<username>/<repo>.git
"'
